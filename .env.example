# --- Bitget API (bitget.com -> Settings -> API Management) ---
# Read permission is enough for market data + read-only arena.
# Trade permission (ideally on a dedicated sub-account) is needed for live orders.
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# --- Bitget Qwen proxy (hackathon), OpenAI-compatible ---
# Used by LLM-driven competitor agents. Optional: agents fall back to a
# deterministic offline policy when no key is present. (QWEN_API_KEY works as an alias.)
BITGET_QWEN_API_KEY=
QWEN_BASE_URL=https://hackathon.bitgetops.com/v1
QWEN_MODEL=qwen3.6-plus

# --- Arena signing key (Ed25519, PEM) ---
# If the file does not exist, a development keypair is generated on first run.
ARENA_SIGNING_KEY_PATH=.keys/arena_ed25519.pem
# For deployment, set ARENA_SIGNING_KEY_B64 (a stable base64 key) instead of the file — see DEPLOY.md.

# Default execution mode for the arena: paper | live-readonly | live
ARENA_MODE=paper
